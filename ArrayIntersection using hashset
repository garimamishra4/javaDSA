class Solution {
    public int[] intersection(int[] nums1, int[] nums2) {
        HashSet<Integer> s1 = new HashSet<>();
        HashSet<Integer> s2 = new HashSet<>();
        for(int n: nums1){
            s1.add(n);
        }
        for(int n: nums2){
            s2.add(n);
        }
        s1.retainAll(s2);
       int[] result = new int[s1.size()];
        int i = 0;

        for(int num : s1){
            result[i++] = num;
        }

        return result;
        
    }
}
