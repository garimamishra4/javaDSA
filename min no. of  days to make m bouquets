class Solution {
    public int minDays(int[] bloomDay, int m, int k) {
        if(bloomDay.length < (long) m * k) return -1;
        
        int l = Integer.MAX_VALUE;
        int h = Integer.MIN_VALUE;

        for(int i : bloomDay){
            l = Math.min(i,l);
            h = Math.max(i,h);
        }

        int ans = -1;

        while(l<=h){
            int mid = l + (h-l)/2;
            if(fxn(bloomDay,m,k,mid)){
                ans = mid;
                h = mid-1;
            }
            else {
                l = mid+1;
            }
        }
        return ans;  
    }

    public boolean fxn(int[] bloomDay , int m , int k , int mid){
        int f = 0, b =0;
        for(int i = 0; i< bloomDay.length ; i++){
            if(bloomDay[i] <= mid){
                f++;

                if(f == k) {
                    b++;
                    f = 0;
                    if(b==m) return true;
                }
            }
            else f = 0;
        }
        return false;
    }
}
