public void generateall(String s , int o, int c , int n, List<String> res){
        if(s.length()== 2 *n) {
            res.add(s);
            return;
        }
        if(o < n) generateall(s+"(" , o+1, c, n, res);
        if(c < o) generateall(s+")",o, c+1, n, res);
    }

    public List<String> generateParenthesis(int n) {
        List<String> res = new ArrayList<>();
        generateall("",0,0,n,res);
        return res;
    }
